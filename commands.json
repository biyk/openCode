{
    "commands": {
        "volumeup": "pactl set-sink-volume @DEFAULT_SINK@ +10%",
        "volumedown": "pactl set-sink-volume @DEFAULT_SINK@ -10%",
        "playpause": "playerctl play-pause",
        "stop": "playerctl stop"
    },
    "match": {
        "volumeup": ["громче", "сделай громче", "увеличь громкость", "громкость вверх"],
        "volumedown": ["тише", "сделай тише", "уменьши громкость", "громкость вниз"],
        "playpause": ["пауза", "плей", "играй", "включи", "стоп", "остановить", "play", "pause", "stop"],
        "stop": ["стоп", "остановить", "выключи"]
    }
}
